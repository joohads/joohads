<?xml version="1.0" encoding="UTF-8"?>
<jasperTemplate xmlns="http://jasperreports.sourceforge.net/jasperreports/template"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/template http://jasperreports.sourceforge.net/xsd/jaspertemplate.xsd">
    <style name="Base" fontName="SansSerif" fontSize="9" pdfFontName="Helvetica"/>
    <style name="ReportTitle" style="Base" mode="Opaque" forecolor="#FFFFFF" backcolor="#1F4E79" fontSize="18" isBold="true"/>
    <style name="SectionHeader" style="Base" mode="Opaque" forecolor="#1F2937" backcolor="#D9EAF7" fontSize="11" isBold="true"/>
    <style name="PositiveVariation" style="Base" forecolor="#047857" isBold="true"/>
    <style name="NegativeVariation" style="Base" forecolor="#B91C1C" isBold="true"/>
    <style name="NeutralVariation" style="Base" forecolor="#4B5563"/>
</jasperTemplate>
