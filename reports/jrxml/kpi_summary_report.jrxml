    <style name="Title" mode="Opaque" forecolor="#FFFFFF" backcolor="#1F4E79" fontName="SansSerif" fontSize="18" isBold="true"/>
    <style name="SectionHeader" mode="Opaque" forecolor="#1F2937" backcolor="#D9EAF7" fontName="SansSerif" fontSize="11" isBold="true"/>
